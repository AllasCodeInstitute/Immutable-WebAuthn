{
  "name": "@simplewebauthn/server",
  "version": "13.3.2",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./helpers": "./src/helpers/index.ts"
  },
  "scripts": {
    "build": "bun run build_npm.ts",
    "test": "bun test src/ --trace-leaks",
    "test:watch": "bun test --watch src/",
    "docs:serve": "python -m http.server -b 127.0.0.1 -d docs",
    "docs:html": "bunx typedoc --out docs src/index.ts",
    "docs:lint": "bunx typedoc --validation src/index.ts",
    "publish": "bun run publish:jsr && bun run publish:npm",
    "publish:jsr": "bun publish",
    "publish:npm": "(cd npm; npm publish)"
  },
  "dependencies": {
    "@hexagon/base64": "^1.1.27",
    "@levischuck/tiny-cbor": "^0.2.2",
    "@peculiar/asn1-android": "^2.6.0",
    "@peculiar/asn1-ecc": "^2.6.1",
    "@peculiar/asn1-rsa": "^2.6.1",
    "@peculiar/asn1-schema": "^2.6.0",
    "@peculiar/asn1-x509": "^2.6.1",
    "@peculiar/x509": "^1.14.3",
    "tiny-cbor": "npm:@levischuck/tiny-cbor@^0.2.2"
  }
}
