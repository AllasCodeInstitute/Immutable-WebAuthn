{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["bun-types"],
    "strict": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@std/assert": ["./test/std/assert.ts"],
      "@std/testing/bdd": ["./test/std/testing/bdd.ts"],
      "@std/testing/mock": ["./test/std/testing/mock.ts"],
      "@std/testing/time": ["./test/std/testing/time.ts"],
      "@std/semver": ["./test/std/semver.ts"],
      "@std/path": ["./test/std/path.ts"]
    }
  }
}
